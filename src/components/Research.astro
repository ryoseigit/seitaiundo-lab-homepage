---
// src/components/Research.astro
const topics = [
  { title: "Actin Binding Proteins", desc: "Fascin, Drebrin, Gelsolinなどの結合タンパク質による構造制御。" },
  { title: "Liposomes", desc: "人工脂質膜を用いた、細胞を模した反応系の構築。" },
  { title: "MreB", desc: "細菌におけるアクチン相同タンパク質の役割解明。" },
  { title: "TIRF Microscopy", desc: "全反射照明蛍光顕微鏡を用いた、1分子レベルでの動態観察。" },
];
---
<section id="research" class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-16">Research</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {topics.map(topic => (
        <div class="p-6 border border-slate-100 rounded-xl shadow-sm hover:shadow-md transition">
          <h3 class="text-xl font-bold mb-4 text-blue-700">{topic.title}</h3>
          <p class="text-slate-600 leading-relaxed">{topic.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>