---
// src/components/Header.astro
const navItems = [
  { name: "Top", href: "#" },
  { name: "Projects", href: "#research" },
  { name: "Publications", href: "https://researchmap.jp/ikuko_fujiwara/published_papers?limit=20"},
  { name: "Presentations", href: "https://researchmap.jp/ikuko_fujiwara/presentations?limit=100" },
  { name: "Members", href: "#members" },
  { name: "Blog", href: "#blog" },
  { name: "Access", href: "#access" },
];
---

<header class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <!-- ロゴ部分 -->
      <div class="flex items-center">
        <a href="/" class="text-xl font-bold text-blue-900 tracking-tighter">
          生体運動 <span class="text-blue-500">研究室</span>
        </a>
      </div>

      <!-- デスクトップナビゲーション -->
      <div class="hidden md:flex space-x-8 items-center">
        {navItems.map(item => (
          <a 
            href={item.href} 
            class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors"
          >
            {item.name}
          </a>
        ))}
        <!-- SNSアイコン（簡易版） -->
        <div class="flex space-x-4 ml-4 border-l pl-4 border-slate-200">
          <a href="https://x.com" target="_blank" class="text-slate-400 hover:text-blue-400">
            <span class="sr-only">X</span>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>

      <!-- スマホ用メニューボタン -->
      <button id="menu-btn" class="md:hidden text-slate-600 focus:outline-none">
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- スマホ用モバイルメニュー -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 animate-fade-in">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="block py-3 text-base font-medium text-slate-600 hover:text-blue-600 border-b border-slate-50"
        >
          {item.name}
        </a>
      ))}
      <div class="flex space-x-6 mt-6">
        <a href="#" class="text-slate-500">Instagram</a>
        <a href="#" class="text-slate-500">X (Twitter)</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // ハンバーガーメニューの開閉制御
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // メニューリンクをクリックしたらメニューを閉じる
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>