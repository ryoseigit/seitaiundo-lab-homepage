---
// src/components/Members.astro

// メンバーデータの定義
const staff = [
  {
    name: "藤原郁子",
    role: "准教授 (Associate Professor)",
    theme: "アクチン動態の全反射顕微鏡観察",
    image: "/~honda-l//ikuko_fujiwara.jpg",
  },
  // {
  //   name: "佐藤 美咲",
  //   role: "助教 (Assistant Professor)",
  //   theme: "MreBと細胞壁合成の相関解析",
  //   image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&q=80&w=200&h=200",
  // },
];

const students = [
  { name: "星田 政行", role: "D2", theme: "アクチンフィラメントのMotility assay" },
  { name: "水木 鳳了", role: "D1", theme: "アクチン結合タンパク質ゲルゾリン" },
  { name: "小野里 幸太", role: "M2", theme: "アクチン変異体の機能解析" },
  { name: "木下 愛友", role: "M2", theme: "アクチン結合タンパク質コフィリン" },
  { name: "田路 卓巳", role: "M1", theme: "アクチン結合タンパク質Fascin" },
  { name: "岩渕 康平", role: "M1", theme: "QCM" },
  { name: "内海 諒成 ", role: "M1", theme: "リポソーム内でのアクチン重合" },
  { name: "熊倉 愛斗", role: "M1", theme: "MreB2の重合観察" },
  { name: "田口 優希", role: "M1", theme: "MreB5の重合観察" },
  { name: "安達 偲", role: "B4", theme: "" },
  { name: "石井 康太郎", role: "B4", theme: "" },
  { name: "岩倉 阿南", role: "B4", theme: "" },
  { name: "小暮 太顕", role: "B4", theme: "" },

  // { name: "三谷 隆大", role: "D3", theme: "Drebrin、サイトカラシンD" }

];
---

<section id="members" class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-16">Members</h2>

    <!-- スタッフセクション -->
    <div class="mb-16">
      <h3 class="text-xl font-bold mb-8 border-l-4 border-blue-600 pl-4 text-slate-800">Staff</h3>
      <div class="grid md:grid-cols-2 gap-8">
        {staff.map(member => (
          <div class="flex items-center p-6 bg-slate-50 rounded-2xl shadow-sm border border-slate-100 transition-hover hover:shadow-md">
            <img 
              src={member.image} 
              alt={member.name} 
              class="w-20 h-20 md:w-24 md:h-24 rounded-full object-cover border-2 border-white shadow-sm"
            />
            <div class="ml-6">
              <p class="text-sm text-blue-600 font-bold mb-1">{member.role}</p>
              <h4 class="text-xl font-bold text-slate-900 mb-2">{member.name}</h4>
              <p class="text-sm text-slate-600 leading-snug">{member.theme}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 学生セクション -->
    <div>
      <h3 class="text-xl font-bold mb-8 border-l-4 border-blue-600 pl-4 text-slate-800">Students</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {students.map(member => (
          <div class="p-5 bg-white border border-slate-200 rounded-xl hover:border-blue-300 transition-colors">
            <span class="inline-block px-2 py-1 rounded bg-blue-50 text-blue-700 text-xs font-bold mb-3">
              {member.role}
            </span>
            <h4 class="text-lg font-bold text-slate-900 mb-2">{member.name}</h4>
            <p class="text-sm text-slate-500">{member.theme}</p>
          </div>
        ))}
        <div class="col-span-full text-center mt-6">
          <a href="./former_member" class="inline-block bg-blue-600 text-white px-6 py-3 rounded-full font-bold hover:bg-blue-700 transition">
            卒業生はこちらから
          </a>
      </div>
    </div>

    <!-- 募集メッセージ（オプション） -->
    <div class="mt-20 p-8 bg-blue-900 rounded-3xl text-center text-white">
      <h3 class="text-xl font-bold mb-4">Join Our Lab</h3>
      <p class="text-blue-100 mb-6 max-w-2xl mx-auto">
        当研究室では、分子生物学や生物物理学に興味のある学生を募集しています。<br class="hidden md:inline">
        見学は随時受け付けております。お気軽にお問い合わせください。
      </p>
      <a href="mailto:contact@example.com" class="inline-block bg-white text-blue-900 px-6 py-2 rounded-full font-bold hover:bg-blue-50 transition">
        お問い合わせ
      </a>
    </div>
  </div>
</section>

<style>
  /* スタッフカードのホバー時の挙動 */
  .transition-hover {
    transition: all 0.3s ease;
  }
</style>