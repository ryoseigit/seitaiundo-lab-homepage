---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import type { Post } from "../../data/posts";
import { posts } from "../../data/posts";

export function getStaticPaths() {
  return posts.map(post => ({
    params: { id: post.id },
    props: { post }
  }));
}

const { post } = Astro.props as { post: Post };
---

<Layout title={`${post.title} | 生体運動研究室`}>
  <Header />
  <main class="pt-28 pb-20 bg-slate-50 min-h-screen">
    <article class="container mx-auto px-6 max-w-5xl bg-white shadow-sm rounded-xl overflow-hidden">
      <img src={post.image} alt={post.title} class="w-full h-72 md:h-96 object-cover" />
      <div class="p-8 md:p-10">
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <span class="px-3 py-1 rounded-full bg-blue-50 text-blue-700 font-semibold">{post.category}</span>
          <span>{post.date}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold mt-4 mb-6 leading-tight">{post.title}</h1>

        <div class="space-y-6 text-slate-700 leading-relaxed">
          {post.content.map(paragraph => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/blog"
            class="inline-flex items-center px-5 py-3 rounded-full bg-blue-600 text-white text-sm font-semibold hover:bg-blue-500 transition"
          >
            ブログ一覧へ戻る
          </a>
          <a
            href="/#blog"
            class="inline-flex items-center px-5 py-3 rounded-full border border-slate-200 text-slate-700 text-sm font-semibold hover:bg-slate-50 transition"
          >
            トップページへ
          </a>
        </div>
      </div>
    </article>
  </main>
</Layout>
