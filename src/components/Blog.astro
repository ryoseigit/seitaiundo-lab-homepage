---
import { posts } from "../data/posts";
---
<section id="blog" class="py-20 bg-slate-50">
  <div class="container mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-16">News / Blog</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {posts.map(post => (
        <a href={`./blog/${post.id}`} class="bg-white rounded-lg overflow-hidden shadow-sm block hover:-translate-y-1 hover:shadow-md transition">
          <img src={post.image} alt={post.title} class="w-full h-48 object-cover" />
          <div class="p-6">
            <span class="text-xs font-bold text-blue-600 uppercase">{post.category}</span>
            <p class="text-sm text-slate-400 mt-1">{post.date}</p>
            <h3 class="text-lg font-bold mt-2 leading-tight">{post.title}</h3>
            <p class="text-sm text-slate-500 mt-3">{post.excerpt}</p>
            <span class="inline-flex items-center text-sm font-semibold text-blue-600 mt-4">続きを読む →</span>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="./blog" class="inline-flex items-center px-6 py-3 text-sm font-semibold text-white bg-blue-600 rounded-full shadow-sm hover:bg-blue-500 transition">
        すべての投稿を見る
      </a>
    </div>
  </div>
</section>