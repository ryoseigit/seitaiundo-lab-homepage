---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Former Members | 生体運動研究室">
  <Header />
  <main class="pt-28 pb-20 bg-slate-50 min-h-screen">
    <section class="container mx-auto px-6">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-wide">Former Members</p>
      <h1 class="text-3xl md:text-4xl font-bold mt-3 mb-6">Former Members</h1>
      <div class="grid gap-4">
        <div class="rounded-xl bg-white p-5 shadow-sm border border-slate-400">三谷 隆大 (D3, 2025)</div>
        <div class="rounded-xl bg-white p-5 shadow-sm border border-slate-400">西村 太希 (M2, 2024)</div>
        <div class="rounded-xl bg-white p-5 shadow-sm border border-slate-400">塩原 大登 (B4, 2023)</div>
        <div class="rounded-xl bg-white p-5 shadow-sm border border-slate-400">IRFANHUZAUFAH AHMAD (B4, 2023)</div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>      